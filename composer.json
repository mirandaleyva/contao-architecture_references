{
  "name": "mirandaleyva/contao-architecture_references",
  "type": "contao-bundle",
  "description": " ",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "contao/core-bundle": "^5.0",
    "contao/manager-plugin": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "MirandaLeyva\\ContaoArchitectureReferences\\": "src/"
    }
  },
  "extra": {
    "contao-manager-plugin": "MirandaLeyva\\ContaoArchitectureReferences\\ContaoManager\\Plugin"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "contao-components/installer": false,
      "php-http/discovery": false,
      "contao/manager-plugin": true
    }
  }
}
