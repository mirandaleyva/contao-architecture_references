{% if references %}
    <div class="architecture-references">
        {% for reference in references %}
            <article class="architecture-reference">
                <h2>{{ reference.title }}</h2>

                {% if reference.short_description %}
                    <p>{{ reference.short_description }}</p>
                {% endif %}

                {% if model.jumpTo and reference.alias %}
                    <p>
                        <a href="{{ reference.alias }}">
                            Mehr erfahren
                        </a>
                    </p>
                {% endif %}
            </article>
        {% endfor %}
    </div>
{% endif %}